# ============================================================
# ODOO WORKSHOP — Variables de Entorno
# Copiar a .env y EDITAR antes de desplegar
# ============================================================
# cp .env.example .env && nano .env
# ============================================================

# Versión de Odoo
ODOO_VERSION=19.0

# PostgreSQL
POSTGRES_DB=odoo_workshop
POSTGRES_USER=odoo_workshop_user
POSTGRES_PASSWORD=CambiarEstaPassword!
POSTGRES_PORT=5432

# Odoo
ODOO_MASTER_PASSWORD=CambiarMasterPassword!
ODOO_ADMIN_EMAIL=admin@techfarma.local
ODOO_PORT=8069
ODOO_LONGPOLLING_PORT=8072

# Nginx / Dominio
NGINX_HOST=odoo.workshop.local
# Para producción: NGINX_HOST=odoo.tudominio.com

# Opcional — Email (se puede omitir en el workshop)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
